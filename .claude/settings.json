{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Read(*)",
      "Write(*)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(cd * && npm *)",
      "Bash(cd * && node *)",
      "Bash(mongod *)",
      "Bash(mongosh *)",
      "Bash(mongodump *)",
      "Bash(mongorestore *)",
      "Bash(mkdir -p *)",
      "Bash(touch *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(chmod +x *)",
      "Bash(lsof *)",
      "Bash(kill *)",
      "Bash(curl *)",
      "Bash(pm2 *)",
      "Bash(cat *)",
      "Bash(echo *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(tail *)",
      "Bash(head *)",
      "Bash(npm run dev)",
      "Bash(npm run dev:server)",
      "Bash(npm run dev:client)",
      "Bash(npm run build)",
      "Bash(npm run seed)",
      "Bash(npm run install:all)",
      "Bash(npm install)",
      "Bash(npm install --omit=dev)",
      "Bash(node server/src/utils/seedData.js)",
      "Bash(NODE_ENV=production pm2 start *)",
      "Bash(NODE_ENV=development *)",
      "Bash(npx kill-port 3000)",
      "Bash(npx kill-port 5000)",
      "Bash(lsof -ti:5000 | xargs kill -9)",
      "Bash(lsof -ti:3000 | xargs kill -9)",
      "Bash(curl -X POST http://localhost:5000/api/auth/register *)",
      "Bash(curl -X POST http://localhost:5000/api/auth/login *)",
      "Bash(curl http://localhost:5000/api/game/config/chefs)",
      "Bash(curl http://localhost:5000/api/game/state *)",
      "Bash(mongosh worldchef --eval *)",
      "Bash(mongosh worldchef)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(sudo rm -rf *)",
      "Bash(DROP DATABASE *)",
      "Bash(git push *)"
    ]
  }
